<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Framework Suite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="com.ecom.listeners.TestListener"/>
    </listeners>
    <test name="E-Commerce End-to-End Tests">
        <classes>
            <class name="com.ecom.tests.OrderPlacementTest"/>
            <class name="com.ecom.tests.ErrorValidationTest"/>
        </classes>
    </test>
</suite>
